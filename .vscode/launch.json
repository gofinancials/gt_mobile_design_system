    "version": "0.2.0",
    "configurations": [
        {
            "name": "gallery",
            "cwd": "gallery",
            "request": "launch",
            "type": "dart",
            "preLaunchTask": "GenerateDirectories",
            "args": [
                "--verbose",
                "--enable-experiment=dot-shorthands"
            ]
        },
        {
            "name": "gallery (profile mode)",
            "cwd": "gallery",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile",
            "preLaunchTask": "GenerateDirectories",
            "args": [
                "--verbose",
                "--enable-experiment=dot-shorthands"
            ]
        },
        {
            "name": "gallery (release mode)",
            "cwd": "gallery",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release",
            "preLaunchTask": "GenerateDirectories",
            "args": [
                "--verbose",
                "--enable-experiment=dot-shorthands"
            ]
        }
    ]
}